<script>
function rc(){var rows=document.querySelectorAll("#gapT tbody tr[data-row]");var aligned=0;
 rows.forEach(function(tr){var inp=tr.querySelector(".agreedin");var pill=tr.querySelector(".gs");
   if(inp.value.trim()!==""){pill.className="statepill ok gs";pill.textContent="Aligned";}
   // third row pre-aligned by agreement even if blank
 });
 // count aligned = rows whose pill says Aligned
 var al=0; rows.forEach(function(tr){if(tr.querySelector(".gs").textContent.trim()==="Aligned")al++;});
 document.getElementById("alignLab").textContent=al+" of "+rows.length+" aligned";
 document.getElementById("alignFill").style.width=(al/rows.length*100)+"%";
 var open=rows.length-al;
 var btn=document.getElementById("gBtn"),t=document.getElementById("gText");
 if(open===0){btn.disabled=false;t.innerHTML="All items aligned — ready to lock the agreed starting point";}
 else{btn.disabled=true;t.innerHTML="<b>"+open+" item"+(open>1?"s":"")+"</b> still open — record an agreed value for each to lock the starting point";}
}
document.querySelectorAll("#gapT .agreedin").forEach(function(el){el.addEventListener("input",rc);});
rc();
</script>

