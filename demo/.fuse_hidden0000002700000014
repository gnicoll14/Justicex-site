<script>
const $=id=>document.getElementById(id);
const num=s=>parseFloat(String(s).replace(/[^0-9.\-]/g,''))||0;
const TOTAL=365;
function recompute(){
  const holD=Math.round(num($('holD').value)), holS=Math.round(num($('holS').value));
  const sumD=Math.round(num($('sumD').value)), sumS=Math.round(num($('sumS').value));
  const brkD=Math.round(num($('brkD').value)), brkS=Math.round(num($('brkS').value));
  $('holT').textContent=holD+holS; $('sumT').textContent=sumD+sumS; $('brkT').textContent=brkD+brkS;
  const dedD=holD+sumD+brkD, dedS=holS+sumS+brkS, ded=dedD+dedS;
  const net=Math.max(0,TOTAL-ded);
  const danaPct=Math.min(100,Math.max(0,num($('regA').value)));
  const dReg=Math.round(net*danaPct/100), sReg=net-dReg;
  const dana=dedD+dReg, sam=dedS+sReg;
  const pctD=dana/TOTAL*100, pctS=sam/TOTAL*100;

  $('dedD').textContent=dedD; $('dedS').textContent=dedS; $('dedT').textContent=ded; $('dedTop').textContent=ded;
  $('netT').textContent=net;
  $('rDana').textContent=dReg; $('rSam').textContent=sReg; $('regT').textContent=net;
  $('regAval').textContent=danaPct+'%';
  $('tDana').textContent=dana; $('tSam').textContent=sam; $('tTot').textContent=dana+sam;
  $('barA').style.width=pctD+'%'; $('barB').style.width=pctS+'%';
  $('pctAbar').textContent=Math.round(pctD)+'%'; $('pctBbar').textContent=Math.round(pctS)+'%';
  $('nA').textContent=dana; $('nB').textContent=sam;
  $('primary').textContent = pctD>pctS ? 'Dana' : (pctS>pctD ? 'Samuel' : 'shared near-equally');
}
function updateResolve(){
  const open=document.querySelectorAll('.tbl .statepill.cont').length;
  const btn=$('resolveBtn'), stat=$('rstat'), txt=$('rstatText');
  if(open===0){ btn.disabled=false; stat.className='rstat done'; stat.innerHTML='<i class="ti ti-circle-check"></i> All topics resolved — ready to finalize'; }
  else { btn.disabled=true; txt.textContent=open+' topic'+(open>1?'s':'')+' still open — resolve all to finalize this page'; }
}
['holD','holS','sumD','sumS','brkD','brkS'].forEach(id=>$(id).addEventListener('input',recompute));
$('regA').addEventListener('input',recompute);
recompute(); updateResolve();
</script>

