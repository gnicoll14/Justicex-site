*{box-sizing:border-box} html,body{margin:0}
body{background:var(--paper); color:var(--ink); font-family:'Source Sans 3',Calibri,system-ui,sans-serif; font-size:15px; line-height:1.6;-webkit-font-smoothing:antialiased;}
.app{max-width:1240px; margin:0 auto; padding:0 22px 60px;}
.appbar{background:var(--navy); color:#fff; display:flex; align-items:center; justify-content:space-between; padding:14px 26px;}
.brand{display:flex; align-items:center;}
.bmark{height:23px; width:23px; border-radius:5px; margin-right:9px;}
.wordmark{font-family:'Source Serif 4',serif; font-weight:600; font-size:22px;} .wordmark .x{color:var(--accent);}
.tagline{font-size:11.5px; letter-spacing:2.4px; text-transform:uppercase; color:#9FB6D2; margin-left:12px;}
.matterchip{font-size:13px; color:#C9D8EA;} .matterchip b{color:#fff; font-weight:600;}
.neutralpill{font-size:11px; color:#08213A; background:var(--accent); padding:4px 11px; border-radius:999px; font-weight:600; margin-left:10px;}
.stages{background:var(--navy-deep); color:#fff; display:flex; align-items:center; padding:9px 26px; flex-wrap:wrap; gap:2px;}
.stage{display:flex; align-items:center; gap:8px; font-size:12.5px; color:#7E9AB9; white-space:nowrap;}
.stage .dot{width:7px;height:7px;border-radius:50%;background:#3C5775;}
.stage.done{color:#B9CBDD;} .stage.done .dot{background:#5C7CA0;}
.stage.active{color:#fff;font-weight:600;} .stage.active .dot{background:var(--accent);box-shadow:0 0 0 4px rgba(216,90,48,.22);}
.stage .sep{width:20px;height:1px;background:#27486B;margin:0 9px;}
.tabs{display:flex; gap:8px; margin:22px 0 4px; flex-wrap:wrap;}
.tab{display:flex; align-items:center; gap:8px; font-size:14px; font-weight:500; padding:9px 16px; border:1px solid var(--hair); background:var(--surface); border-radius:999px; color:var(--muted); cursor:pointer;}
.tab.active{background:var(--navy); color:#fff; border-color:var(--navy);}
.panel{background:var(--surface); border:1px solid var(--hair); border-radius:var(--radius); padding:24px 26px 28px; margin-top:14px; box-shadow:0 1px 2px rgba(20,30,46,.04);}
h1{font-family:'Source Serif 4',serif; font-weight:500; font-size:26px; margin:0 0 4px;}
.lede{color:var(--muted); margin:0 0 18px; max-width:74ch;}
.sec{font-size:12px; letter-spacing:.5px; text-transform:uppercase; color:var(--faint); font-weight:600; margin:24px 0 12px; display:flex; align-items:center; gap:8px;}
.sec .add{margin-left:auto; font-size:12px; font-weight:600; color:var(--navy2); text-transform:none; letter-spacing:0; cursor:pointer; display:inline-flex; align-items:center; gap:5px; border:1px dashed #B9CBE2; border-radius:7px; padding:3px 10px;}
.kids{display:flex; gap:10px; flex-wrap:wrap; margin-bottom:14px;}
.kid{display:flex; align-items:center; gap:8px; border:1px solid var(--hair); border-radius:999px; padding:6px 13px; font-size:13.5px; font-weight:600;}
.kid i{color:var(--navy3);} .kid span{font-weight:400; color:var(--muted);}
.grid2{display:grid; grid-template-columns:1fr 1fr; gap:18px;} @media(max-width:880px){.grid2{grid-template-columns:1fr}}
.pos{border:1px solid var(--hair); border-radius:var(--radius-sm); padding:14px 16px;}
.pos.a{background:var(--a-soft);} .pos.b{background:var(--b-soft);}
.pos .nm{font-weight:600; font-size:13.5px; display:flex; align-items:center; gap:7px;} .pos.a .nm{color:var(--a-ink);} .pos.b .nm{color:var(--b-ink);}
.pos .tx{font-size:13px; color:var(--ink); margin-top:5px;}
/* split bar */
.splitbar{display:flex; height:32px; border-radius:9px; overflow:hidden; border:1px solid var(--hair); margin:2px 0 4px;}
.splitbar .pa{background:var(--a);} .splitbar .pb{background:var(--b);}
.splitbar div{display:flex;align-items:center;justify-content:center;color:#fff;font-size:12.5px;font-weight:600; min-width:0; white-space:nowrap; transition:width .12s;}
.barcap{display:flex; justify-content:space-between; font-size:12.5px; color:var(--muted); margin-bottom:4px;} .barcap b{color:var(--ink);}
.xnote{font-size:12.5px; background:var(--accent-soft); border:1px solid #F1CDBE; border-radius:8px; padding:9px 13px; margin:12px 0 4px; display:flex; gap:9px; align-items:flex-start;} .xnote i{color:var(--accent-d); font-size:17px; margin-top:1px;} .xnote b{color:var(--accent-d);}
/* allocation table */
.tbl{border:1px solid var(--hair); border-radius:var(--radius-sm); overflow:hidden; margin-top:6px;}
.tbl .h,.tbl .r{display:grid; gap:10px; align-items:center;}
.sched .h,.sched .r{grid-template-columns:1.5fr 1.85fr 58px 64px 60px 92px 26px;}
.dom .h,.dom .r{grid-template-columns:1.2fr .95fr 1.95fr 96px 28px;}
.tbl .h{padding:9px 14px; background:#E2EAF4; font-size:10.5px; letter-spacing:.4px; text-transform:uppercase; color:var(--navy2); font-weight:700;}
.tbl .h .cellnum{text-align:right;}
.tbl .r{padding:11px 14px; border-top:1px solid var(--hair); font-size:13.5px;}
.tbl .subhead{padding:8px 14px; border-top:1px solid var(--hair); font-size:10.5px; letter-spacing:.5px; text-transform:uppercase; font-weight:700;}
.subhead.oneoff{background:#F4F8FD; color:var(--navy2);}
.subhead.routine{background:#F1F0F4; color:#5A4B6B;}
.tbl .r.topline{background:var(--blue-soft);} .tbl .r.topline .lab{color:var(--navy); font-weight:700;} .tbl .r.topline .cellnum{color:var(--navy); font-weight:700;}
.tbl .r.sub{background:var(--blue-soft2); font-weight:600;}
.tbl .r.net{background:var(--accent-soft);} .tbl .r.net .lab,.tbl .r.net .cellnum,.tbl .r.net .op{color:var(--accent-d); font-weight:700;}
.tbl .r.driven{background:var(--gray);}
.tbl .r.grand{background:var(--navy);} .tbl .r.grand .lab,.tbl .r.grand .cellnum{color:#fff; font-weight:700;}
.tbl .addrow{padding:8px 14px; border-top:1px dashed var(--gray-bd); font-size:12.5px; color:var(--navy2); font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px;}
.tbl .lab{font-weight:600; color:var(--navy2);}
.tbl .lab small{display:block; font-weight:400; color:var(--muted); font-size:11.5px;}
.op{font-size:11.5px; color:var(--muted); font-weight:600;}
.cellnum{text-align:right; font-variant-numeric:tabular-nums; font-weight:600;}
.cellnum.calc{color:var(--muted);}
.cellnum input{width:50px; padding:4px 7px; border:1px solid #CDDDF3; border-radius:6px; font-size:13px; text-align:right; font-variant-numeric:tabular-nums; font-family:inherit;}
.coltot{color:var(--navy2);}
.rowslider{display:flex; align-items:center; gap:9px;}
.rowslider input[type=range]{flex:1; accent-color:var(--a); min-width:90px;}
.rowslider .pv{font-size:11.5px; font-weight:700; color:var(--a-ink); white-space:nowrap;}
.note{font-size:12px; color:var(--muted);}
.statepill{font-size:10.5px; padding:3px 9px; border-radius:999px; font-weight:600; white-space:nowrap; cursor:pointer; display:inline-flex; align-items:center; gap:4px;}
.statepill.ok{background:var(--success-s); color:var(--success);} .statepill.cont{background:var(--accent-soft); color:var(--accent-d);}
.edit{color:var(--faint); cursor:pointer; text-align:center;} .edit:hover{color:var(--navy2);}
.arr{font-size:12.5px; font-weight:600; padding:3px 10px; border-radius:7px; display:inline-flex; align-items:center; gap:6px; cursor:pointer;}
.arr.joint{background:#EAF1FB; color:var(--navy2);} .arr.a{background:var(--a-soft); color:var(--a-ink);} .arr.b{background:var(--b-soft); color:var(--b-ink);}
.arr .ti{font-size:13px; opacity:.6;}
.cap{font-size:11.5px; color:var(--faint); margin:8px 2px 0; display:flex; align-items:center; gap:6px;}
/* law */
.lawband{border:1px solid var(--hair); border-radius:var(--radius-sm); padding:14px 16px; background:#FBFDFF;}
.lawpill{display:inline-flex; align-items:center; gap:8px; font-size:12.5px; color:var(--navy2); background:#EAF1FB; border:1px solid #CFE0F4; padding:6px 12px; border-radius:8px;}
.quote{font-size:12.5px; color:var(--ink); font-style:italic; border-left:3px solid var(--navy3); padding:6px 12px; margin-top:10px; background:#fff;} .quote b{font-style:normal; color:var(--navy);}
.plain{font-size:13px; color:var(--ink); margin-top:10px;} .plain b{color:var(--navy);}
/* resolution approach */
.dispute{border:1px solid var(--hair); border-radius:var(--radius-sm); padding:16px 18px; background:#FBFDFF;}
.dispute .d-int{font-size:13px; color:var(--muted); margin:0 0 12px;}
.ladder{display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:12px;}
.step{display:flex; align-items:center; gap:7px; background:#EAF1FB; border:1px solid #CFE0F4; border-radius:8px; padding:7px 12px; font-size:12.5px; font-weight:600; color:var(--navy2);}
.step .n{width:18px;height:18px;border-radius:50%;background:var(--navy);color:#fff;font-size:11px;display:flex;align-items:center;justify-content:center;}
.step.last{background:var(--accent-soft); border-color:#F1CDBE; color:var(--accent-d);} .step.last .n{background:var(--accent-d);}
.ladder .arw{color:var(--faint);}
.dispute textarea{width:100%; min-height:78px; border:1px solid #CDDDF3; border-radius:8px; padding:10px 12px; font-family:inherit; font-size:13px; color:var(--ink); resize:vertical;}
.dispute .who{font-size:11.5px; color:var(--faint); margin-top:8px; display:flex; align-items:center; gap:6px;}
/* reports + resolve */
.reports{display:flex; gap:12px; flex-wrap:wrap;}
.rep{display:flex; align-items:center; gap:11px; border:1px solid var(--hair); border-radius:var(--radius-sm); padding:13px 16px; min-width:230px; cursor:pointer; background:var(--surface);}
.rep i{font-size:22px; color:var(--navy);} .rep .rt{font-weight:600; font-size:14px;} .rep .rs{font-size:11.5px; color:var(--muted);}
.resolvebar{display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-top:18px; background:#F6F9FD; border:1px solid var(--hair); border-radius:var(--radius-sm); padding:13px 18px;}
.resolvebar .rstat{font-size:13px; display:flex; align-items:center; gap:8px;}
.resolvebar .rstat.open{color:var(--accent-d);} .resolvebar .rstat.done{color:var(--success); font-weight:600;}
.btn{font-size:13px; font-weight:600; border:1px solid var(--hair); background:var(--surface); color:var(--ink); border-radius:9px; padding:10px 16px; cursor:pointer; display:inline-flex; align-items:center; gap:7px;}
.btn.accent{background:var(--accent); color:#fff; border-color:var(--accent);}
.btn:disabled{background:#E7EBF1; color:#9AA3B0; border-color:#DCE2EA; cursor:not-allowed;}
.framing{display:flex; gap:11px; align-items:flex-start; max-width:84ch; margin-top:18px;}
.framing i{color:var(--accent); font-size:22px;} .framing p{margin:0; font-size:13px; color:var(--muted);} .framing b{color:var(--navy); font-weight:600;}
.disc{font-size:11.5px; color:var(--faint); margin-top:18px; line-height:1.7; border-top:1px solid var(--hair); padding-top:12px; display:flex; justify-content:space-between; gap:16px; flex-wrap:wrap;} .disc .tfe b{color:var(--navy);}

