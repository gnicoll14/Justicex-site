<style>
:root{
  --navy:#042C53; --navy-deep:#021A33; --navy2:#154572; --navy3:#2A5582;
  --paper:#E6F1FB; --surface:#FFFFFF; --ink:#1A1A1A; --muted:#5F5E5A; --faint:#9CA0A7; --hair:#D1DEEE;
  --accent:#D85A30; --accent-d:#B04722; --accent-soft:#FAECE7; --success:#1D9E75; --success-s:#E7F4EF; --danger:#C73E3E;
  --a:#2A5582; --a-soft:#E6F1FB; --a-ink:#154572; --b:#D67E5F; --b-soft:#FAECE7; --b-ink:#B04722;
