<script id="jxr-js">
(function(){
 if(window.__jxrail) return; window.__jxrail=1;
 var STEPS=[['plan.html','Plan'],['intake.html','Intake'],['redact.html','Redact'],['summarize.html','Summarize'],['gap-analysis.html','Gap Analysis'],['resolution.html','Resolution'],['memorandum.html','Memorandum']];
 var MAP={'plan.html':1,'intake.html':2,'redact.html':3,'summarize.html':4,'gap-analysis.html':5,'resolution.html':6,'memorandum.html':7,'strength-comparison.html':5,'children.html':5,'finances.html':5,'support.html':5};
 function init(){
   var path=(location.pathname.split('/').pop()||'').toLowerCase(); var cur=MAP[path]||0;
   var chips='';
   STEPS.forEach(function(s,i){ var n=i+1; var cls=n<cur?'done':(n===cur?'cur':'up');
     var inner=n<cur?'<i class="ti ti-check"></i>':n;
     chips+='<a class="jxr-s '+cls+'" href="'+s[0]+'" title="Step '+n+' · '+s[1]+'"><span class="jxr-n">'+inner+'</span><span class="jxr-l">'+s[1]+'</span></a>';
     if(n<7) chips+='<span class="jxr-sep"></span>';
   });
   // type-aware scope label: party_model = 'two' (default) | 'one'. Two-party: 1-4 each / 5-7 both. One-sided: applicant throughout.
   var PARTY=(window.JX_PARTY||'two');
   var scopeTxt = PARTY==='one' ? 'You — the applicant'
       : (cur===0 ? '' : (cur<=4 ? 'Each party · on their own' : 'Both parties · together'));
   var scopeHtml = scopeTxt ? '<span class="jxr-scope"><i class="ti ti-users"></i>'+scopeTxt+'</span>' : '<span style="margin-left:auto"></span>';
   var curLabel = cur? ('Step '+cur+' of 7') : 'Overview';
   var bar=document.createElement('div'); bar.className='jxr';
   bar.innerHTML='<div class="jxr-in"><a class="jxr-bc" href="dashboard.html"><i class="ti ti-layout-grid"></i> Dashboard</a>'
     +'<span class="jxr-bcs">›</span><span class="jxr-mt">Whitfield</span>'
     +'<div class="jxr-steps">'+chips+'</div>'+scopeHtml+'<span class="jxr-mini">'+curLabel+'</span></div>';
   var anchor=document.querySelector('.rolebar')||document.querySelector('.appbar');
   if(anchor&&anchor.parentNode){ anchor.parentNode.insertBefore(bar, anchor.nextSibling); }
   else { document.body.insertBefore(bar, document.body.firstChild); }
 }
 if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init); else init();
})();
</script>
<!-- /jx-progress-rail -->
</body>
</html>
